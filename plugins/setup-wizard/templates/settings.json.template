{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "_comment_allow": "Read, Glob, and Grep are safe read-only tools. Write and Edit are allowed here for speed — move them to 'ask' if you want Claude to confirm before every file change.",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash({{TEST_CMD_BASENAME}}:*)",
      "Bash({{LINT_CMD_BASENAME}}:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(sudo rm:*)",
      "Bash(chmod -R 777:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)"
    ],
    "_comment_deny": "Curl-pipe-shell patterns are blocked by hooks/block-dangerous-bash.sh because they require regex matching that Bash permissions do not support.",
    "ask": [
      "Bash(git push:*)",
      "Bash({{DEPLOY_CMD_BASENAME}}:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/block-dangerous-bash.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/auto-format.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/statusline.sh",
    "padding": 0
  },
  "env": {
    "CLAUDE_TEST_CMD": "{{TEST_CMD}}"
  }
}
